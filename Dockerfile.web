FROM node:20-slim AS build

WORKDIR /app

COPY web/package.json web/package-lock.json* web/bun.lockb* ./
RUN npm install

COPY web/ .

# .env já contém VITE_SUPABASE_URL e VITE_SUPABASE_KEY
# Essas são chaves públicas (anon key) — seguro incluir no build
COPY web/.env .env

RUN npm run build

FROM nginx:alpine

COPY --from=build /app/dist /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
